<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="dark" />
  <title>XeonDB - Billing</title>
  <meta name="description" content="Billing overview for your XeonDB account." />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap"
    rel="stylesheet" />

  <link rel="icon" href="/logo.png" />
  <link rel="stylesheet" href="/css/billing.css" />
</head>

<body>
  <%- include('alert.ejs') %>

  <% const list = Array.isArray(instances) ? instances : []; %>
  <% const freeCount = list.filter((x) => String((x && x.plan) ? x.plan : 'free').toLowerCase() !== 'pro').length; %>
  <% const proCount = list.filter((x) => String((x && x.plan) ? x.plan : 'free').toLowerCase() === 'pro').length; %>

  <main class="page">
    <div class="shell">
      <div class="topbar">
        <a class="brand" href="/" aria-label="Back to XeonDB home">
          <img src="/logo.png" alt="XeonDB logo" />
          <span>XeonDB</span>
        </a>
        <div class="topbarRight">
          <a class="btn" href="/dashboard">Dashboard</a>
          <details class="userMenu">
            <summary class="userAvatar" aria-label="Open user menu"><%= name %></summary>
            <div class="userMenuPop" role="navigation" aria-label="User menu">
              <a class="userMenuItem" href="/settings">Settings</a>
              <a class="userMenuItem" href="/billing" aria-current="page">Billing</a>
              <div class="userMenuSep" aria-hidden="true"></div>
              <a class="userMenuItem" href="/logout">Logout</a>
            </div>
          </details>
        </div>
      </div>

      <header class="header">
        <div>
          <h1 class="title">Billing</h1>
          <p class="subtitle">Account-level overview. Payments and invoices are coming soon.</p>
        </div>
      </header>

      <section class="grid">
        <div class="card">
          <div class="cardTitle">Plan Footprint</div>
          <div class="stats">
            <div class="stat">
              <div class="statNum mono"><%= freeCount %></div>
              <div class="statLabel">Free instances</div>
            </div>
            <div class="stat">
              <div class="statNum mono"><%= proCount %></div>
              <div class="statLabel">Pro instances</div>
            </div>
            <div class="stat">
              <div class="statNum mono"><%= list.length %></div>
              <div class="statLabel">Total</div>
            </div>
          </div>
          <div class="hint">To change a database plan, open the database and use its Billing tab.</div>
        </div>

        <div class="card">
          <div class="cardTitle">Databases</div>
          <% if (list.length) { %>
            <div class="tableWrap">
              <table class="table">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Plan</th>
                    <th>Keyspace</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  <% list.forEach(function(inst) { %>
                    <% const plan = String((inst && inst.plan) ? inst.plan : 'free').toLowerCase(); %>
                    <tr>
                      <td>
                        <div class="dbName"><%= (inst && (inst.name || inst.id)) ? (inst.name || inst.id) : '-' %></div>
                        <div class="dbSub mono"><%= inst && inst.id ? inst.id : '' %></div>
                      </td>
                      <td><span class="pill <%= plan === 'pro' ? 'pro' : 'free' %>"><%= plan === 'pro' ? 'pro' : 'free' %></span></td>
                      <td class="mono"><%= inst && inst.keyspace ? inst.keyspace : '-' %></td>
                      <td class="actions">
                        <a class="btn btnSmall" href="/dashboard/<%= inst.id %>">Open</a>
                        <% if (plan !== 'pro') { %>
                          <button class="btn btnSmall" type="button" data-upgrade="<%= inst.id %>">Upgrade</button>
                        <% } %>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="empty">No databases yet. Create one from your dashboard.</div>
          <% } %>
        </div>

        <div class="card">
          <div class="cardTitle">Invoices</div>
          <div class="hint">Not available yet.</div>
        </div>
      </section>
    </div>
  </main>

  <script>
    (function () {
      async function startUpgrade(instanceId) {
        const r = await fetch('/api/billing/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ instanceId: instanceId })
        });
        const data = await r.json().catch(function () { return null; });
        if (!r.ok || !data || !data.url) {
          alert((data && data.error) ? data.error : 'Failed to start checkout');
          return;
        }
        window.location.href = data.url;
      }

      document.addEventListener('click', function (e) {
        const t = e && e.target ? e.target : null;
        if (!t) return;
        const id = t.getAttribute && t.getAttribute('data-upgrade');
        if (!id) return;
        startUpgrade(String(id));
      });
    })();
  </script>
</body>

</html>
