              badge.textContent = 'Allow All';
            } else if (isYourIp) {
              badge.className = 'whitelistBadge auto';
              badge.textContent = 'Your IP';
            } else if (kind === 'auto') {
              badge.className = 'whitelistBadge auto';
              badge.textContent = 'Auto';
            } else {
              badge.className = 'whitelistBadge custom';
              badge.textContent = 'Custom';
