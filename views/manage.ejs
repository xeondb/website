          if (!res.ok || !data) {
            throw new Error((data && (data.error || data.message)) || ('Request failed (' + res.status + ')'));
          }
          return data;
        }

        async function deleteJson(url) {
          const res = await fetch(url, { method: 'DELETE', credentials: 'same-origin' });
          const data = await res.json().catch(() => null);
          if (!res.ok || !data) {
            throw new Error((data && (data.error || data.message)) || ('Request failed (' + res.status + ')'));
